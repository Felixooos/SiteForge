<!-- Fullscreen Overlay Navigation -->
<button class="nav-fullscreen-trigger" aria-label="Menu">
  <div class="nav-fullscreen-icon">
    <span></span><span></span>
  </div>
</button>

<div class="nav-fullscreen-overlay">
  <div class="nav-fullscreen-content">
    <% if (config.logo && config.navigation.logoInNav) { %>
    <img class="nav-fullscreen-logo" src="<%= config.logo %>" alt="Logo">
    <% } %>
    <nav class="nav-fullscreen-links">
      <% sections.forEach((s, i) => { %>
      <a href="#section-<%= s.id %>" style="animation-delay: <%= 0.1 + i * 0.06 %>s">
        <span class="nav-fullscreen-num">0<%= i + 1 %></span>
        <span class="nav-fullscreen-label"><%= s.label %></span>
      </a>
      <% }) %>
    </nav>
    <% if (config.navigation.showFooter) { %>
    <div class="nav-fullscreen-footer"><%= config.navigation.footerText || '© ' + new Date().getFullYear() + ' ' + config.projectName %></div>
    <% } %>
  </div>
</div>
