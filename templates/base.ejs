    .classement-empty { text-align: center; padding: 30px; color: var(--text); opacity: 0.5; }
    /* ===== BOUTIQUE ===== */
    .boutique-admin-bar { display: flex; gap: 10px; margin-bottom: 18px; }
    .boutique-btn { padding: 12px 20px; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; font-size: 15px; transition: all 0.2s; font-family: var(--font-body); }
    .boutique-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
    .boutique-btn-add { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; }
    .boutique-btn-sync { background: linear-gradient(135deg, #3498db, #2980b9); color: white; }
    .boutique-btn-confirm { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; }
    .boutique-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; }
