  // ==================== CLASSEMENT ====================
  async function loadClassement(email) {
    const { data: etudiants } = await sb.from('etudiants').select('*').eq('site_id', SITE_ID);
    const { data: transactions } = await sb.from('transactions').select('destinataire_email, montant').eq('site_id', SITE_ID);
    const { data: achats } = await sb.from('achats').select('acheteur_email, prix_paye').eq('site_id', SITE_ID);

    allUsers = (etudiants || []).filter(e => !e.is_admin).map(e => {
      const gains = (transactions || []).filter(t => t.destinataire_email === e.email).filter(t => t.montant > 0).reduce((s, t) => s + t.montant, 0);
      const spent = (achats || []).filter(a => a.acheteur_email === e.email).reduce((s, a) => s + a.prix_paye, 0);
      return { ...e, total_gains: gains, solde_reel: gains - spent };
    }).sort((a, b) => b.total_gains - a.total_gains);

    const me = allUsers.find(u => u.email === email);
    const myRank = allUsers.findIndex(u => u.email === email) + 1;

    const card = document.getElementById('classement-user-card');
    if (card && me) {
      card.style.display = 'block';
      document.getElementById('classement-user-rank').textContent = myRank <= 3 ? myRank + (myRank === 1 ? 'ère' : 'ème') + ' place' : myRank + 'ème place';
      document.getElementById('classement-user-name').textContent = (me.pseudo || formatName(email)).toUpperCase();
      document.getElementById('classement-user-solde').textContent = me.total_gains + ' ' + CURRENCY;
    }

    const soldeEl = document.getElementById('profil-solde');
    if (soldeEl && me) soldeEl.textContent = me.solde_reel + ' ' + CURRENCY;

    renderClassement(allUsers, email);
  }

  function renderClassement(users, email) {
    const list = document.getElementById('classement-list');
    if (!list) return;
    list.innerHTML = '';
    users.forEach((u, i) => {
      const isMe = u.email === email;
      const rank = allUsers.indexOf(u) + 1;
      const row = document.createElement('div');
      row.className = 'classement-row';
      if (isMe) row.classList.add('is-me');
      else if (rank === 1) row.classList.add('rank-1');
      else if (rank === 2) row.classList.add('rank-2');
      else if (rank === 3) row.classList.add('rank-3');

      row.innerHTML = '<div class="classement-row-left"><span class="classement-row-badge">' + rank + '.</span><span class="classement-row-name">' + (u.pseudo || formatName(u.email)) + '</span></div><span class="classement-row-score">' + u.total_gains + ' ' + CURRENCY + '</span>';

      if (isAdmin && !isMe) {
        row.style.cursor = 'pointer';
        row.addEventListener('click', () => openAdminModal(u.email, u.solde_reel));
      }
      list.appendChild(row);
    });
  }

  const searchInput = document.getElementById('classement-search');
  if (searchInput) searchInput.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    const filtered = allUsers.filter(u => u.email.toLowerCase().includes(q) || (u.pseudo || '').toLowerCase().includes(q));
    renderClassement(filtered, currentEmail);
  });

  // ==================== ADMIN MODAL ====================
  let adminTarget = '';
  function openAdminModal(targetEmail, solde) {
    adminTarget = targetEmail;
    let overlay = document.getElementById('sf-admin-modal');
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.id = 'sf-admin-modal';
      overlay.className = 'admin-modal-overlay';
      overlay.innerHTML = '<div class="sf-modal-card" style="max-width:420px;"><button class="member-modal-close" id="admin-modal-close">✕</button><h3 class="sf-modal-title">⚙️ Admin — <span id="admin-target-name"></span></h3><div class="sf-modal-form"><label>Montant</label><input type="number" id="admin-modal-amount" min="1" placeholder="100"><label>Raison</label><input type="text" id="admin-modal-reason" placeholder="Challenge, récompense..."><div style="display:flex;gap:10px;margin-top:12px;"><button class="boutique-btn boutique-btn-sync" style="flex:1;" id="admin-btn-add">+ Ajouter</button><button class="boutique-btn boutique-btn-add" style="flex:1;" id="admin-btn-remove">- Retirer</button></div></div></div>';
      document.body.appendChild(overlay);
      overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });
      document.getElementById('admin-modal-close').addEventListener('click', () => overlay.classList.remove('open'));
      document.getElementById('admin-btn-add').addEventListener('click', () => adminAction('add'));
      document.getElementById('admin-btn-remove').addEventListener('click', () => adminAction('remove'));
    }
    document.getElementById('admin-target-name').textContent = targetEmail;
    document.getElementById('admin-modal-amount').value = '';
    document.getElementById('admin-modal-reason').value = '';
    overlay.classList.add('open');
  }

  async function adminAction(type) {
    const amount = parseInt(document.getElementById('admin-modal-amount').value);
    const reason = document.getElementById('admin-modal-reason').value.trim();
    if (!amount || amount <= 0 || !reason) return alert('Montant positif et raison requis');
    const { data: u } = await sb.from('etudiants').select('solde').eq('email', adminTarget).eq('site_id', SITE_ID).single();
    if (!u) return alert('Utilisateur non trouvé');
    if (type === 'add') {
      await sb.from('etudiants').update({ solde: (u.solde || 0) + amount }).eq('email', adminTarget).eq('site_id', SITE_ID);
      await sb.from('transactions').insert([{ destinataire_email: adminTarget, montant: amount, raison: reason, admin_email: currentEmail, site_id: SITE_ID }]);
    } else {
      if ((u.solde || 0) - amount < 0) return alert('Solde insuffisant !');
      await sb.from('etudiants').update({ solde: (u.solde || 0) - amount }).eq('email', adminTarget).eq('site_id', SITE_ID);
      await sb.from('achats').insert([{ acheteur_email: adminTarget, nom: '⚠️ Retrait Admin: ' + reason, prix_paye: amount, site_id: SITE_ID }]);
    }
    document.getElementById('sf-admin-modal').classList.remove('open');
    await loadClassement(currentEmail);
    await loadGainsAchats(currentEmail);
  }

  // ==================== GAINS & ACHATS ====================
  async function loadGainsAchats(email) {
    const { data: transactions } = await sb.from('transactions').select('*').eq('destinataire_email', email).eq('site_id', SITE_ID).order('created_at', { ascending: false });
    const { data: achats } = await sb.from('achats').select('*').eq('acheteur_email', email).eq('site_id', SITE_ID).order('date_achat', { ascending: false });

    const gainsBody = document.getElementById('profil-body-gains');
    if (gainsBody) {
      gainsBody.innerHTML = '';
      if (!transactions || transactions.length === 0) {
        gainsBody.innerHTML = '<div class="profil-list-empty">Aucun gain</div>';
      } else {
        transactions.forEach(t => {
          gainsBody.innerHTML += '<div class="profil-gain-item"><span>' + (t.raison || 'Gain') + '</span><span>+' + t.montant + ' ' + CURRENCY + '</span></div>';
        });
      }
    }
    const achatsBody = document.getElementById('profil-body-achats');
    if (achatsBody) {
      achatsBody.innerHTML = '';
      if (!achats || achats.length === 0) {
        achatsBody.innerHTML = '<div class="profil-list-empty">Aucun achat</div>';
      } else {
        achats.forEach(a => {
          achatsBody.innerHTML += '<div class="profil-achat-item"><span>' + (a.nom || 'Achat') + '</span><span>-' + a.prix_paye + ' ' + CURRENCY + '</span></div>';
        });
      }
    }
  }

  // ==================== BOUTIQUE ====================
  async function loadBoutique() {
    const { data: objets } = await sb.from('objets_boutique').select('*').eq('is_published', true).eq('site_id', SITE_ID).order('id', { ascending: true });
    const grid = document.getElementById('boutique-grid');
    if (!grid) return;
    grid.innerHTML = '';
    if (!objets || objets.length === 0) {
      grid.innerHTML = '<div class="classement-empty">Aucun objet en vente</div>';
      return;
    }
    objets.forEach(obj => {
      const epuise = !obj.is_tombola && obj.quantite <= 0;
      const taille = obj.taille || 'petit';
      const isTombola = obj.is_tombola || false;
      const isGratuit = obj.prix === 0;
      const div = document.createElement('div');
      div.className = 'boutique-item size-' + taille;

      let imgHtml = obj.image_url
        ? '<img class="boutique-item-img" src="' + obj.image_url + '" alt="' + obj.nom + '">'
        : '<div class="boutique-item-placeholder">🛍️</div>';

      let btnText = 'Acheter';
      let btnClass = 'boutique-item-buy';
      if (isTombola) { btnText = isGratuit ? '🎁 Participer' : 'Acheter un ticket'; btnClass += ' boutique-item-tombola'; }
      else if (isGratuit) { btnText = '🎁 Obtenir'; btnClass += ' boutique-item-gratuit'; }

      let stockHtml = '';
      if (!isTombola) stockHtml = '<p class="boutique-item-stock ' + (epuise ? 'epuise' : '') + '">' + (epuise ? 'Épuisé' : 'Quantité: ' + obj.quantite) + '</p>';

      div.innerHTML = '<button class="boutique-item-menu" data-id="' + obj.id + '">⋮</button>' + imgHtml + '<div class="boutique-item-info"><p class="boutique-item-name">' + obj.nom + '</p><p class="boutique-item-prix">' + obj.prix + ' ' + CURRENCY + '</p>' + stockHtml + '</div><button class="' + btnClass + '" data-id="' + obj.id + '" data-nom="' + obj.nom + '" data-prix="' + obj.prix + '" ' + (epuise ? 'disabled' : '') + '>' + btnText + '</button>';
      grid.appendChild(div);
    });

    // Buy buttons — require login
    grid.querySelectorAll('.boutique-item-buy').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!currentEmail) {
          alert('Connecte-toi pour acheter ! Va dans Mon Profil ou recharge la page.');
          return;
        }
        const id = parseInt(btn.dataset.id);
        const nom = btn.dataset.nom;
        const prix = parseInt(btn.dataset.prix);
        confirmPurchase(id, nom, prix);
      });
    });

    // Menu buttons (admin)
    if (isAdmin || isBoutiqueManager) {
      grid.querySelectorAll('.boutique-item-menu').forEach(btn => {
        btn.style.display = 'block';
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = parseInt(btn.dataset.id);
          if (confirm('Supprimer cet objet ?')) {
            sb.from('objets_boutique').update({ admin_deleted: true }).eq('id', id).eq('site_id', SITE_ID).then(() => loadBoutique());
          }
        });
      });
    }
  }

  let pendingPurchase = null;
  function confirmPurchase(id, nom, prix) {
    const modal = document.getElementById('boutique-modal-confirm');
    if (!modal) return;
    document.getElementById('boutique-confirm-text').textContent = 'Acheter "' + nom + '" pour ' + prix + ' ' + CURRENCY + ' ?';
    modal.style.display = 'flex';
    pendingPurchase = { id, nom, prix };
  }

  const btnBuyConfirm = document.getElementById('btn-boutique-buy-confirm');
  if (btnBuyConfirm) btnBuyConfirm.addEventListener('click', async () => {
    if (!pendingPurchase) return;
    if (!currentEmail) return alert('Connecte-toi d\'abord');
    const { id, nom, prix } = pendingPurchase;
    const { data: me } = await sb.from('etudiants').select('solde').eq('email', currentEmail).eq('site_id', SITE_ID).single();
    if (!me) return alert('Erreur profil');
    const soldeReel = allUsers.find(u => u.email === currentEmail)?.solde_reel || 0;
    if (soldeReel < prix) return alert('Solde insuffisant !');
    await sb.from('etudiants').update({ solde: (me.solde || 0) - prix }).eq('email', currentEmail).eq('site_id', SITE_ID);
    const { data: obj } = await sb.from('objets_boutique').select('quantite, is_tombola').eq('id', id).eq('site_id', SITE_ID).single();
    if (obj && !obj.is_tombola && obj.quantite > 0) {
      await sb.from('objets_boutique').update({ quantite: obj.quantite - 1 }).eq('id', id).eq('site_id', SITE_ID);
    }
    await sb.from('achats').insert([{ acheteur_email: currentEmail, nom, prix_paye: prix, site_id: SITE_ID }]);
    document.getElementById('boutique-modal-confirm').style.display = 'none';
    pendingPurchase = null;
    await loadClassement(currentEmail);
    await loadGainsAchats(currentEmail);
    await loadBoutique();
    alert('Achat effectué !');
  });

  // ==================== BOUTIQUE ADD (admin) ====================
  const btnBoutiqueAdd = document.getElementById('btn-boutique-add');
  if (btnBoutiqueAdd) btnBoutiqueAdd.addEventListener('click', () => {
    document.getElementById('boutique-edit-id').value = '';
    document.getElementById('boutique-obj-nom').value = '';
    document.getElementById('boutique-obj-prix').value = '';
    document.getElementById('boutique-obj-quantite').value = '1';
    document.getElementById('boutique-obj-image').value = '';
    document.getElementById('boutique-obj-tombola').checked = false;
    document.getElementById('boutique-obj-gratuit').checked = false;
    document.getElementById('boutique-obj-gratuit').disabled = true;
    document.getElementById('boutique-preview').style.display = 'none';
    document.getElementById('boutique-modal-title').textContent = '➕ Ajouter un Objet';
    document.getElementById('btn-boutique-confirm').textContent = 'Ajouter';
    document.getElementById('boutique-modal-add').style.display = 'flex';
  });

  document.querySelectorAll('.boutique-size-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.boutique-size-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('boutique-obj-taille').value = btn.dataset.size;
    });
  });

  const uploadZone = document.getElementById('boutique-upload-zone');
  const photoInput = document.getElementById('boutique-obj-photo');
  if (uploadZone) {
    uploadZone.addEventListener('click', () => photoInput.click());
    photoInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        document.getElementById('boutique-preview-img').src = ev.target.result;
        document.getElementById('boutique-preview').style.display = 'block';
      };
      reader.readAsDataURL(file);
    });
  }

  const tombolaCheck = document.getElementById('boutique-obj-tombola');
  const gratuitCheck = document.getElementById('boutique-obj-gratuit');
  if (tombolaCheck) tombolaCheck.addEventListener('change', () => {
    gratuitCheck.disabled = !tombolaCheck.checked;
    if (!tombolaCheck.checked) { gratuitCheck.checked = false; document.getElementById('boutique-obj-prix').disabled = false; }
  });
  if (gratuitCheck) gratuitCheck.addEventListener('change', () => {
    document.getElementById('boutique-obj-prix').disabled = gratuitCheck.checked;
    if (gratuitCheck.checked) document.getElementById('boutique-obj-prix').value = '0';
  });

  const btnConfirm = document.getElementById('btn-boutique-confirm');
  if (btnConfirm) btnConfirm.addEventListener('click', async () => {
    const nom = document.getElementById('boutique-obj-nom').value.trim();
    const prix = parseInt(document.getElementById('boutique-obj-prix').value) || 0;
    const quantite = parseInt(document.getElementById('boutique-obj-quantite').value) || 0;
    const taille = document.getElementById('boutique-obj-taille').value;
    const isTombola = document.getElementById('boutique-obj-tombola').checked;
    let imageUrl = document.getElementById('boutique-obj-image').value.trim();

    if (!nom) return alert('Nom requis');

    const file = document.getElementById('boutique-obj-photo').files[0];
    if (file) {
      const path = 'boutique/' + Date.now() + '_' + file.name;
      const { error: upErr } = await sb.storage.from('sites').upload(path, file, { upsert: true });
      if (!upErr) {
        const { data: urlData } = sb.storage.from('sites').getPublicUrl(path);
        imageUrl = urlData.publicUrl;
      }
    }

    const obj = { nom, prix, quantite, image_url: imageUrl, taille, is_tombola: isTombola, is_published: false, site_id: SITE_ID };
    const editId = document.getElementById('boutique-edit-id').value;
    if (editId) {
      await sb.from('objets_boutique').update(obj).eq('id', parseInt(editId)).eq('site_id', SITE_ID);
    } else {
      await sb.from('objets_boutique').insert([obj]);
    }
    document.getElementById('boutique-modal-add').style.display = 'none';
    await loadBoutique();
  });

  const btnSync = document.getElementById('btn-boutique-sync');
  if (btnSync) btnSync.addEventListener('click', async () => {
    await sb.from('objets_boutique').delete().eq('admin_deleted', true).eq('site_id', SITE_ID);
    await sb.from('objets_boutique').update({ is_published: true }).eq('is_published', false).eq('site_id', SITE_ID);
    await loadBoutique();
    alert('Boutique synchronisée !');
  });

  // ==================== DÉFIS ====================
  async function loadDefis() {
    const grid = document.getElementById('defis-grid');
    if (!grid) return;

    // Load challenges: super_admin/admin see all, users see only published
    let query = sb.from('challenges').select('*').eq('site_id', SITE_ID).eq('admin_deleted', false);
    if (!isAdmin && !isSuperAdmin) {
      query = query.eq('published', true);
    }
    const { data: defis } = await query.order('created_at', { ascending: false });

    // Load validations for current user + all validations for admin view
    const { data: allValidations } = await sb.from('challenge_validations').select('*').eq('site_id', SITE_ID);

    grid.innerHTML = '';
    if (!defis || defis.length === 0) {
      grid.innerHTML = '<div class="classement-empty">Aucun défi disponible</div>';
      return;
    }

    defis.forEach(defi => {
      const myValidation = (allValidations || []).find(v => v.challenge_id === defi.id && v.user_email === currentEmail);
      const defiValidations = (allValidations || []).filter(v => v.challenge_id === defi.id);
      const isDraft = !defi.published;

      const div = document.createElement('div');
      div.className = 'defi-card' + (isDraft ? ' defi-card-draft' : '');
      div.dataset.points = defi.points;

      // Badge color from categories config or default
      let badgeColor = 'var(--primary)';
      const cats = <%- JSON.stringify((config.sections.find(s => s.type === 'defis') || { config: { categories: [] } }).config.categories || []) %>;
      const matchCat = cats.find(c => c.points === defi.points);
      if (matchCat) badgeColor = matchCat.color;

      let statusHtml = '';
      if (myValidation) {
        statusHtml = '<span class="defi-card-status validated">✅ Validé</span>';
      }

      let actionsHtml = '';
      // Admin can validate for someone
      if (isAdmin || isSuperAdmin) {
        actionsHtml += '<button class="defi-btn-validate" data-id="' + defi.id + '">✅ Valider pour qqn</button>';
      }
      // Super admin can delete
      if (isSuperAdmin) {
        actionsHtml += '<button class="defi-btn-delete" data-id="' + defi.id + '">🗑️</button>';
      }

      let validatedListHtml = '';
      if ((isAdmin || isSuperAdmin) && defiValidations.length > 0) {
        validatedListHtml = '<div class="defi-validated-list">' + defiValidations.map(v => '<span class="defi-validated-tag">✅ ' + formatName(v.user_email) + '</span>').join('') + '</div>';
      }

      div.innerHTML = '<div class="defi-card-header"><span class="defi-card-title">' + (defi.titre || '') + '</span><span class="defi-badge" style="background:' + badgeColor + '">' + defi.points + ' ' + CURRENCY + '</span></div>'
        + '<p class="defi-card-desc">' + (defi.description || '') + '</p>'
        + '<div class="defi-card-footer">' + (isDraft ? '<span class="defi-card-status pending">📝 Brouillon</span>' : statusHtml) + '</div>'
        + (actionsHtml ? '<div class="defi-card-actions">' + actionsHtml + '</div>' : '')
        + validatedListHtml;

      grid.appendChild(div);
    });

    // Validate buttons
    grid.querySelectorAll('.defi-btn-validate').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('defis-validate-id').value = btn.dataset.id;
        document.getElementById('defis-validate-email').value = '';
        document.getElementById('defis-modal-validate').style.display = 'flex';
      });
    });

    // Delete buttons
    grid.querySelectorAll('.defi-btn-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Supprimer ce défi ?')) return;
        await sb.from('challenges').update({ admin_deleted: true }).eq('id', parseInt(btn.dataset.id)).eq('site_id', SITE_ID);
        await loadDefis();
      });
    });
  }

  // Defis tab filtering
  const defisTabs = document.getElementById('defis-tabs');
  if (defisTabs) {
    defisTabs.querySelectorAll('.defis-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        defisTabs.querySelectorAll('.defis-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        const grid = document.getElementById('defis-grid');
        if (!grid) return;
        grid.querySelectorAll('.defi-card').forEach(card => {
          if (filter === 'all') { card.style.display = ''; }
          else { card.style.display = card.dataset.points === filter ? '' : 'none'; }
        });
      });
    });
  }

  // Add defi modal
  const btnDefisAdd = document.getElementById('btn-defis-add');
  if (btnDefisAdd) btnDefisAdd.addEventListener('click', () => {
    document.getElementById('defis-edit-id').value = '';
    document.getElementById('defis-obj-titre').value = '';
    document.getElementById('defis-obj-description').value = '';
    document.getElementById('defis-modal-title').textContent = '➕ Nouveau Défi';
    document.getElementById('btn-defis-confirm').textContent = 'Créer';
    document.getElementById('defis-modal-add').style.display = 'flex';
  });

  // Difficulty selector
  document.querySelectorAll('.defis-diff-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.defis-diff-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('defis-obj-points').value = btn.dataset.points;
    });
  });

  // Confirm add/edit defi
  const btnDefisConfirm = document.getElementById('btn-defis-confirm');
  if (btnDefisConfirm) btnDefisConfirm.addEventListener('click', async () => {
    const titre = document.getElementById('defis-obj-titre').value.trim();
    const description = document.getElementById('defis-obj-description').value.trim();
    const points = parseInt(document.getElementById('defis-obj-points').value) || 50;
    if (!titre) return alert('Titre requis');

    const obj = { titre, description, points, published: false, admin_deleted: false, site_id: SITE_ID };
    const editId = document.getElementById('defis-edit-id').value;
    if (editId) {
      await sb.from('challenges').update({ titre, description, points }).eq('id', parseInt(editId)).eq('site_id', SITE_ID);
    } else {
      await sb.from('challenges').insert([obj]);
    }
    document.getElementById('defis-modal-add').style.display = 'none';
    await loadDefis();
  });

  // Publish all drafts
  const btnDefisSync = document.getElementById('btn-defis-sync');
  if (btnDefisSync) btnDefisSync.addEventListener('click', async () => {
    await sb.from('challenges').update({ published: true }).eq('published', false).eq('admin_deleted', false).eq('site_id', SITE_ID);
    await loadDefis();
    alert('Défis publiés !');
  });

  // Validate defi for a user
  const btnDefisValidateConfirm = document.getElementById('btn-defis-validate-confirm');
  if (btnDefisValidateConfirm) btnDefisValidateConfirm.addEventListener('click', async () => {
    const challengeId = parseInt(document.getElementById('defis-validate-id').value);
    const userEmail = document.getElementById('defis-validate-email').value.trim().toLowerCase();
    if (!userEmail || !challengeId) return alert('Email requis');

    // Check user exists
    const { data: user } = await sb.from('etudiants').select('email, solde').eq('email', userEmail).eq('site_id', SITE_ID).single();
    if (!user) return alert('Utilisateur non trouvé sur ce site');

    // Check not already validated
    const { data: existing } = await sb.from('challenge_validations').select('id').eq('challenge_id', challengeId).eq('user_email', userEmail).eq('site_id', SITE_ID).maybeSingle();
    if (existing) return alert('Déjà validé pour cet utilisateur');

    // Get challenge points
    const { data: challenge } = await sb.from('challenges').select('points, titre').eq('id', challengeId).eq('site_id', SITE_ID).single();
    if (!challenge) return alert('Défi introuvable');

    // Insert validation
    await sb.from('challenge_validations').insert([{ challenge_id: challengeId, user_email: userEmail, validated_by: currentEmail, site_id: SITE_ID }]);

    // Award points
    await sb.from('etudiants').update({ solde: (user.solde || 0) + challenge.points }).eq('email', userEmail).eq('site_id', SITE_ID);
    await sb.from('transactions').insert([{ destinataire_email: userEmail, montant: challenge.points, raison: '🏆 Défi: ' + challenge.titre, admin_email: currentEmail, site_id: SITE_ID }]);

    document.getElementById('defis-modal-validate').style.display = 'none';
    await loadDefis();
    await loadClassement(currentEmail);
    alert('Défi validé ! +' + challenge.points + ' ' + CURRENCY + ' pour ' + userEmail);
  });

})();
</script>
<% } %>
</body>
</html>