    .boutique-item-prix { color: var(--primary); font-weight: 800; font-size: 1.1rem; }
    .boutique-item-stock { font-size: 13px; color: var(--text); opacity: 0.6; margin: 4px 0; }
    .boutique-item-stock.epuise { color: #e74c3c; opacity: 1; font-weight: 700; }
    .boutique-item-buy { width: 90%; padding: 10px; margin: 0 auto 12px; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 15px; color: white; background: var(--primary); transition: all 0.2s; display: block; }
    .boutique-item-buy:hover:not(:disabled) { transform: scale(1.03); box-shadow: 0 3px 10px rgba(0,0,0,0.2); }
    .boutique-item-buy:disabled { background: #ddd; cursor: not-allowed; color: #999; }
    .boutique-item-tombola { background: linear-gradient(135deg, #f39c12, #e67e22) !important; }
    .boutique-item-gratuit { background: linear-gradient(135deg, #00b8d4, #0097a7) !important; }
    .boutique-item-menu { position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 32px; height: 32px; cursor: pointer; font-size: 16px; display: none; z-index: 2; }
    .boutique-size-btns { display: flex; gap: 8px; margin: 5px 0 10px; }
    .boutique-size-btn { flex: 1; padding: 8px; border: 2px solid rgba(0,0,0,0.1); border-radius: 8px; background: linear-gradient(135deg, var(--card-bg), var(--card-bg-end)); cursor: pointer; font-weight: 600; font-family: var(--font-body); color: var(--text); transition: all 0.2s; }
    .boutique-size-btn.active { border-color: var(--primary); background: rgba(231,76,60,0.1); }
    .boutique-upload-zone { border: 2px dashed rgba(0,0,0,0.15); border-radius: 10px; padding: 20px; text-align: center; cursor: pointer; transition: all 0.2s; margin-top: 5px; }
    .boutique-upload-zone:hover { border-color: var(--primary); background: rgba(0,0,0,0.02); }
    /* ===== PROFIL ===== */
    .profil-login-screen { max-width: 450px; margin: 0 auto; }
    .profil-login-card { background: linear-gradient(135deg, var(--card-bg), var(--card-bg-end)); padding: 35px 30px; border-radius: 18px; box-shadow: 0 8px 30px rgba(0,0,0,0.15); text-align: center; }
    .profil-login-card h2 { font-family: var(--font-heading); color: var(--text); margin-bottom: 20px; }
    .profil-tabs { display: flex; gap: 8px; margin-bottom: 20px; }
    .profil-tab { flex: 1; padding: 12px; border: none; border-radius: 10px; cursor: pointer; font-weight: 700; font-size: 15px; font-family: var(--font-body); transition: all 0.2s; background: rgba(0,0,0,0.05); color: var(--text); }
    .profil-tab.active { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; }
    .profil-form { display: flex; flex-direction: column; gap: 12px; }
